# AgentGolem Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --- LLM Providers ---
# Store API keys for each provider you use.  The provider name must match
# a key in settings.yaml → llm_providers.  Naming convention: <PROVIDER>_API_KEY
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Legacy per-route overrides (optional — provider registry above is preferred)
LLM_DISCUSSION_API_KEY=
LLM_DISCUSSION_BASE_URL=
LLM_CODE_API_KEY=
LLM_CODE_BASE_URL=

# --- Email (SMTP for sending) ---
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=agent@example.com
EMAIL_SMTP_PASSWORD=your-smtp-password-here

# --- Email (IMAP for reading) ---
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_USER=agent@example.com
EMAIL_IMAP_PASSWORD=your-imap-password-here

# --- Moltbook ---
MOLTBOOK_API_KEY=your-moltbook-api-key-here
MOLTBOOK_BASE_URL=https://moltbook.example.com/api

# --- Google Custom Search (Programmable Search Engine) ---
# Uses API key + search engine ID (cx). OAuth is NOT used for Custom Search.
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# --- Google OAuth (for future Gmail / Drive integration) ---
# Use a Desktop App OAuth client downloaded from Google Cloud Console.
# Keep the JSON file local-only and gitignored.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_FILE=config/google_oauth_client.json
GOOGLE_OAUTH_TOKEN_FILE=data/google/oauth_token.json
