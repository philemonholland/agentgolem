# AgentGolem settings — copy to settings.yaml and customise.
# Agents may self-optimise most values at runtime;
# sleep/wake durations are protected and cannot be changed by agents.

data_dir: data
awake_duration_minutes: 10.0
sleep_duration_minutes: 5.0
wind_down_minutes: 2.0
soul_update_min_confidence: 0.7
sleep_cycle_minutes: 5.0
sleep_max_nodes_per_cycle: 1000
sleep_max_time_ms: 5000
sleep_phase_cycle_length: 6           # Sleep macro-cycle length in dream walks
sleep_phase_split: 0.67               # Fraction of the macro-cycle spent in consolidation
sleep_state_top_k: 128                # Persisted top active nodes for resuming mid-sleep
sleep_membrane_decay: 0.82            # Base membrane leak/decay per timestep
sleep_consolidation_threshold: 0.95   # Spike threshold during consolidation phase
sleep_dream_threshold: 0.75           # Lower spike threshold during associative dream phase
sleep_refractory_steps: 2             # Timesteps a node stays refractory after spiking
sleep_stdp_window_steps: 3            # Timestep window for timing-aware plasticity
sleep_stdp_strength: 0.08             # Strength of STDP-like reinforce/weaken updates
sleep_dream_noise: 0.18               # Associative noise injected during dream phase
llm_provider: openai
llm_model: gpt-5
llm_discussion_model: deepseek-reasoner   # regular discussion model when DEEPSEEK_API_KEY is set
llm_code_model: gpt-5.4        # model used for codebase inspection & evolution (higher quality)

# --- LLM Provider Registry ---
# Map provider names to base URLs.  API keys go in .env as <PROVIDER>_API_KEY.
# To switch models: just change llm_discussion_model and llm_discussion_provider.
# Example: to use gpt-5.4-mini for discussion, set:
#   llm_discussion_provider: openai
#   llm_discussion_model: gpt-5.4-mini
llm_providers:
  openai: https://api.openai.com/v1
  deepseek: https://api.deepseek.com/v1
llm_discussion_provider: ""    # empty = auto-detect from legacy env vars
llm_code_provider: ""          # empty = auto-detect from legacy env vars
log_level: INFO
email_enabled: false
moltbook_enabled: false
google_custom_search_enabled: false
google_gmail_api_enabled: false
google_drive_api_enabled: false
dry_run_mode: false
approval_required_actions:
- email_send
- moltbook_send
niscalajyoti_revisit_hours: 6.0
retention_archive_days: 5
retention_purge_days: 30
retention_min_trust_useful: 0.1
retention_min_centrality: 0.05
retention_promote_min_accesses: 10
retention_promote_min_trust_useful: 0.5
quarantine_emotion_threshold: 0.7
quarantine_trust_useful_threshold: 0.3
browser_rate_limit_per_minute: 10
browser_timeout_seconds: 20
google_custom_search_default_num_results: 5
google_custom_search_hourly_quota: 4
google_custom_search_bucket_capacity: 100
google_custom_search_safe: active
llm_request_delay_seconds: 3.0   # cooldown between LLM requests (protected)
agent_count: 7
agent_offset_minutes: 0.0
autonomous_interval_seconds: 60.0
name_discovery_cycles: 4
peer_checkin_interval_minutes: 30.0
peer_message_max_chars: 3000
discussion_max_completion_tokens: 2048    # token room for discussion completions
reflection_max_tokens: 1024               # token room for reflections / heartbeat writing
encoding_max_tokens: 16384                # token room for memory encoding / decomposition
discussion_target_paragraphs: 5           # prompt target for discussion response length
llm_temperature: 0.7
llm_top_p: 1.0
llm_frequency_penalty: 0.0
llm_presence_penalty: 0.0
discussion_transcript_max_entries: 30     # rolling transcript memory for council dialogue
repo_root: ""                  # workspace boundary (empty = auto-detect from install location)

# Consciousness kernel
metacognition_interval: 3            # ticks between metacognitive reflection passes
narrative_synthesis_interval: 15     # ticks between narrative chapter synthesis
self_model_rebuild_interval: 10      # ticks between self-model reconstruction
attention_influence_weight: 0.7      # how strongly attention directive biases action (0-1)
internal_state_mycelium_share: true  # share internal state read-only via mycelium
metacognition_novelty_bias: 0.3      # how much "stuck" detection pushes toward novelty

# Dashboard tuning
dashboard_refresh_interval_seconds: 5   # polling interval for live dashboard refresh
dashboard_recent_change_seconds: 60     # how long a signal is marked as "recently changed"
dashboard_dialogue_limit: 10            # how many recent dialogue turns to show
dashboard_activity_limit: 6             # how many recent thoughts/actions to show per agent
dashboard_settings_history_limit: 25    # how many recent setting-change events to show
